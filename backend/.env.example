# ============================================================
# Future Artist - Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# REQUIRED — the app will not start without these
# ------------------------------------------------------------

# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ------------------------------------------------------------
# OPTIONAL — safe defaults are provided for local development
# ------------------------------------------------------------

# Gemini model to use (gemini-2.5-flash recommended)
GEMINI_MODEL=gemini-2.5-flash

# Google Cloud project ID (not required for local Gemini API usage)
GOOGLE_CLOUD_PROJECT=your-project-id

# Service account credentials (not required when using GEMINI_API_KEY directly)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Region
GCP_REGION=us-central1

# Cloud Storage bucket for media (leave empty to skip storage)
# CLOUD_STORAGE_BUCKET=futureartist-media

# Server
PORT=8000
HOST=0.0.0.0
DEBUG=true
LOG_LEVEL=INFO

# CORS — allow the frontend origin
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Secret Manager (keep false for local dev)
USE_SECRET_MANAGER=false

# Agent concurrency
MAX_CONCURRENT_AGENTS=6
STREAM_TIMEOUT=300
